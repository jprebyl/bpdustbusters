---
import Layout from '../layouts/Layout.astro';
---
<Layout title="BP Dust Busters — Car & Bin Cleaning">

  <nav>
    <div class="nav-brand">BP Dust Busters</div>
    <a href="tel:9133491932" class="nav-cta">(913) 349-1932</a>
  </nav>

  <section class="hero">
    <div class="hero-inner">
      <h1 class="hero-name">BP<br /><em>DUST</em><br />BUSTERS</h1>
      <p class="hero-tagline">Your car deserves it. Your bins too.</p>
      <div class="hero-actions">
        <a href="#contact" class="btn btn-white">Book a clean</a>
        <a href="#services" class="btn btn-ghost">See services</a>
      </div>
    </div>
  </section>

  <section class="services" id="services">
    <p class="eyebrow">What we do</p>
    <h2 class="section-head">Three services.<br />All spotless.</h2>
    <div class="service-grid">

      <div class="service-card">
        <svg class="service-icon" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M7 26h30M9 26l3.5-9h19L35 26" stroke="currentColor" stroke-width="2.2" stroke-linejoin="round"/>
          <circle cx="13.5" cy="31.5" r="3.5" stroke="currentColor" stroke-width="2.2"/>
          <circle cx="30.5" cy="31.5" r="3.5" stroke="currentColor" stroke-width="2.2"/>
          <path d="M17 31.5h10M5.5 26v5h2M38.5 26v5h-2" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
          <path d="M30 8c1.5 2 2.5 4.5 2.5 4.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" opacity="0.45"/>
          <path d="M34 6c1.5 2.5 2 5 2 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" opacity="0.3"/>
          <path d="M26 10c1 1.5 1.5 3.5 1.5 3.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" opacity="0.3"/>
        </svg>
        <div class="service-name">Exterior Wash</div>
        <p class="service-desc">Full wash, rinse, and hand dry. Every panel, every wheel arch. Your car leaves looking the way it should.</p>
        <div class="service-price"><sup>$</sup>20</div>
      </div>

      <div class="service-card">
        <svg class="service-icon" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect x="6" y="10" width="32" height="26" rx="2" stroke="currentColor" stroke-width="2.2"/>
          <path d="M6 18h32" stroke="currentColor" stroke-width="2.2"/>
          <path d="M16 10v8M28 10v8" stroke="currentColor" stroke-width="2.2"/>
          <path d="M14 26l4 4 8-8" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <div class="service-name">Interior Detail</div>
        <p class="service-desc">Vacuumed, wiped down, windows cleaned. Open the door and it smells like you just picked it up.</p>
        <div class="service-price"><sup>$</sup>20</div>
      </div>

      <div class="service-card">
        <svg class="service-icon" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M13 17h18l-2.5 22h-13L13 17z" stroke="currentColor" stroke-width="2.2" stroke-linejoin="round"/>
          <path d="M9 17h26" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
          <path d="M17.5 17v-4a1.5 1.5 0 0 1 1.5-1.5h6a1.5 1.5 0 0 1 1.5 1.5v4" stroke="currentColor" stroke-width="2.2"/>
          <path d="M19 23v10M25 23v10" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
        </svg>
        <div class="service-name">Trash Can Cleaning</div>
        <p class="service-desc">Hot water rinse, deodorizer, full scrub. No more being that neighbor on pickup day.</p>
        <div class="service-price"><sup>$</sup>15</div>
      </div>

    </div>
  </section>

  <section class="process">
    <div class="process-inner">
      <p class="eyebrow" style="color: rgba(255,255,255,0.8);">The process</p>
      <h2 class="section-head">Simple from start<br />to finish.</h2>
      <div class="steps">
        <div>
          <div class="step-num">01</div>
          <div class="step-name">Book online or call</div>
          <p class="step-desc">Tell us what you need and when works. We'll confirm your slot the same day.</p>
        </div>
        <div>
          <div class="step-num">02</div>
          <div class="step-name">We come to you</div>
          <p class="step-desc">We show up at your home or driveway — you don't have to go anywhere or do anything.</p>
        </div>
        <div>
          <div class="step-num">03</div>
          <div class="step-name">Pick it up clean</div>
          <p class="step-desc">Your car or bins are done. You'll know the difference the moment you see them.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="about">
    <div class="about-grid">
      <div>
        <p class="eyebrow">About us</p>
        <h2 class="section-head">Local kids.<br />Honest work.</h2>
        <p class="about-body">
          BP Dust Busters is <strong>Bobby and P</strong> — two guys from Eudora who
          started this business because they wanted to earn it themselves. They show up on time,
          do the job right, and won't leave until you're happy with it. No cutting corners,
          no excuses.
        </p>
        <p class="about-body" style="margin-top: 1rem;">
          <strong>Serving Eudora and surrounding areas.</strong>
        </p>
      </div>
      <div class="reasons">
        <div class="reason">
          <div class="reason-icon">
            <svg viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M9 2v7l4 2" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              <circle cx="9" cy="9" r="7" stroke="currentColor" stroke-width="2"/>
            </svg>
          </div>
          <div class="reason-text">
            <strong>We come to you</strong>
            <p>No dropping off, no waiting around. We show up at your driveway on your schedule.</p>
          </div>
        </div>
        <div class="reason">
          <div class="reason-icon">
            <svg viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M3 9l4 4 8-8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="reason-text">
            <strong>Honest pricing</strong>
            <p>You'll know the price before we start. What we quote is what you pay.</p>
          </div>
        </div>
        <div class="reason">
          <div class="reason-icon">
            <svg viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M9 2C5.5 2 3 5 3 8c0 4 6 9 6 9s6-5 6-9c0-3-2.5-6-6-6z" stroke="currentColor" stroke-width="2"/>
              <circle cx="9" cy="8" r="2" stroke="currentColor" stroke-width="2"/>
            </svg>
          </div>
          <div class="reason-text">
            <strong>We're your neighbors</strong>
            <p>We live here too. Our reputation in this community matters to us more than anything.</p>
          </div>
        </div>
        <div class="reason">
          <div class="reason-icon">
            <svg viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M9 2l1.8 5h5.2l-4.2 3 1.6 5L9 12l-4.4 3 1.6-5L2 7h5.2L9 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="reason-text">
            <strong>We stand behind our work</strong>
            <p>If something isn't right, say the word and we'll make it right. Simple as that.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="team">
    <div class="team-inner">
      <p class="eyebrow" style="color: rgba(255,255,255,0.6);">The crew</p>
      <h2 class="section-head">Meet the crew.</h2>
      <div class="team-grid">
        <div class="team-card">
          <div class="team-photo">
            <img src="/photos/bobby.jpeg" alt="Bobby" />
          </div>
          <div class="team-name">Bobby</div>
          <div class="team-role">Co-founder</div>
        </div>
        <div class="team-card">
          <div class="team-photo">
            <!-- Replace with: <img src="/photos/parker.jpeg" alt="Parker" /> -->
            <span class="photo-initial">P</span>
          </div>
          <div class="team-name">P</div>
          <div class="team-role">Co-founder</div>
        </div>
      </div>
    </div>
  </section>

  <section class="trust">
    <p class="trust-line">We clean what most people put off until they can't ignore it anymore.</p>
    <p class="trust-sub">Local &nbsp;&middot;&nbsp; Reliable &nbsp;&middot;&nbsp; Done right the first time</p>
  </section>

  <section class="contact" id="contact">
    <p class="eyebrow">Book a clean</p>
    <h2 class="section-head">Ready when<br />you are.</h2>
    <a href="tel:9133491932" class="contact-phone">(913) 349-1932</a>
    <p class="contact-sub">Call or fill out the form and we'll confirm your appointment within 24 hours.</p>

    <form class="form" action="https://formspree.io/f/mwvdpdvv" method="post">
      <input type="hidden" name="_subject" value="New booking request — BP Dust Busters" />
      <div class="row-2">
        <div class="field">
          <label for="name">Your name</label>
          <input type="text" id="name" name="name" autocomplete="name" placeholder="Jane Smith" required />
        </div>
        <div class="field">
          <label for="phone">Phone number</label>
          <input type="tel" id="phone" name="phone" autocomplete="tel" placeholder="(555) 000-0000" required />
        </div>
      </div>

      <div class="field field-select">
        <label for="service">Service needed</label>
        <select id="service" name="service" required>
          <option value="" disabled selected>Choose a service&hellip;</option>
          <option value="exterior">Exterior wash</option>
          <option value="interior">Interior detail</option>
          <option value="trash">Trash can cleaning</option>
          <option value="all">All three</option>
        </select>
      </div>

      <div class="field">
        <label for="address">Address</label>
        <input type="text" id="address" name="address" autocomplete="street-address" placeholder="123 Main St, Your Town" />
      </div>

      <div class="field">
        <label for="notes">Anything we should know?</label>
        <textarea id="notes" name="notes" placeholder="Vehicle make and model, number of bins, preferred time of day&hellip;"></textarea>
      </div>

      <div>
        <button type="submit" class="btn btn-solid">Send request</button>
      </div>
      <p class="form-note">We'll reach out by phone to confirm. No spam, ever.</p>
    </form>
  </section>

  <footer>
    <div class="footer-brand">BP Dust Busters</div>
    <a href="tel:9133491932" class="footer-phone">(913) 349-1932</a>
    <div class="footer-copy">&copy; 2026 BP Dust Busters. All rights reserved.</div>
  </footer>

</Layout>
